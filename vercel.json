{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "next build",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "cleanUrls": true,
  "trailingSlash": false,
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/calculator", "destination": "/" }
  ],
  "github": {
    "silent": true
  },
  "env": {
    "NEXT_PUBLIC_BUILD_ENV": "VERCEL"
  },
  "buildOptions": {
    "uploadTimeout": 120000,
    "minRetryWaitTime": 3000
  }
} 