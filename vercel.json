{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=1, stale-while-revalidate=59"
        }
      ]
    }
  ],
  "rewrites": [],
  "redirects": [],
  "framework": {
    "version": 3,
    "name": "nextjs"
  },
  "buildCommand": "next build",
  "installCommand": "pnpm install",
  "regions": ["iad1"],
  "outputDirectory": ".next"
} 