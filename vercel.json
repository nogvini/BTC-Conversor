{
  "buildCommand": "next build",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "regions": ["iad1"],
  "github": {
    "silent": true
  },
  "env": {
    "NEXT_PUBLIC_BUILD_ENV": "VERCEL"
  },
  "buildOptions": {
    "uploadTimeout": 120000,
    "minRetryWaitTime": 3000
  }
} 